# Carbon footprint service (separate Cloudflare Worker, see ~/carbon-svc)
CARBON_SVC_URL=https://carbon-svc.good-neighbor.workers.dev
CARBON_SVC_API_KEY=

# Better Stack / Logtail (server-side logging). Optional in dev — leave
# blank to disable logging. Required in production (set in Cloudflare Pages).
BETTER_STACK_ENDPOINT=
BETTER_STACK_TOKEN=

# Existing secrets (already wired elsewhere; listed here for reference)
# MONDAY_API_TOKEN=
# LOCATION_IQ_API_KEY=
# REPLICATE_API_TOKEN=
# FETCHER_SECRET=
